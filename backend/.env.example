# ── Server ────────────────────────────────────────────────
# Port the backend listens on (default: 8080)
PORT=8080

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production set this to the exact IP/hostname of the infoscreen TV.
# Example for a LAN deployment where the TV browser opens http://192.168.1.100
ALLOWED_ORIGINS=http://192.168.1.100,http://192.168.1.100:8080

# ── Authentication ────────────────────────────────────────
# Generate the hash with:  node scripts/hash-passphrase.js
# That script also prints a ready SESSION_SECRET for you.
PASSPHRASE_HASH=<salt>:<hex-hash>

# Random secret for signing JWTs — generate once with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=<replace-with-strong-random-string>

# How many days before the browser must log in again (default: 10)
SESSION_DAYS=10

# ── Notes ─────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# Recommended production setup:
#   1. Run `npm run build` in /frontend
#   2. Run `node src/server.js` in /backend
#      Express will automatically serve the built frontend
#      from frontend/dist — no separate web server needed.
#
#   3. Put nginx / Caddy in front for TLS (HTTPS).
#      nginx example snippet:
#        server {
#          listen 443 ssl;
#          server_name infoscreen.yourdomain.local;
#          ssl_certificate     /etc/ssl/certs/infoscreen.crt;
#          ssl_certificate_key /etc/ssl/private/infoscreen.key;
#          location / { proxy_pass http://127.0.0.1:8080; }
#        }
